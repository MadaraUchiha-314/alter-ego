{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogTitle": "# Changelog\n\nAll notable changes to the alter-ego plugin, generated by semantic-release from\nConventional Commits on merges to `main`. See\n[docs/capabilities/release-automation.md](docs/capabilities/release-automation.md)."
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "bun scripts/set-version.ts ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [".claude-plugin/plugin.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
